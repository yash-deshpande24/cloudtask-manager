@keyframes svgFadeInScale {=20
  0% { opacity: 0; scale: 0.95; }
  100% { opacity: 1; scale: 1; }
}

#vis-container.streaming :where(svg, circle, rect, path, polygon, polyline,=
 line, ellipse, g, text):not([transform]):not([opacity]) { transition: fill=
 0.4s ease-out, stroke 0.4s ease-out, opacity 0.4s ease-out; animation: 0.5=
s ease-out 0s 1 normal none running svgFadeInScale; transform-origin: cente=
r center; }
