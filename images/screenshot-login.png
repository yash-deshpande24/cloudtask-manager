oject</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">unzip</span><span> cloudtask-manager.zip
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Step 2 — Go into project folder</span><span>
