</span></span><span><span></span><span class="token token" style="color: rgb(251, 173, 96);">cd</span><span> cloudtask-manager
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Initialize git (if not done)</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">git</span><span> init
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">git</span><span> </span><span class="token token" style="color: rgb(112, 184, 255);">add</span><span> </span><span class="token token" style="color: rgb(251, 173, 96);">.</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">git</span><span> commit -m </span><span class="token token" style="color: rgb(155, 233, 99);">"Initial commit: CloudTask Manager - AWS DevOps Project"</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Connect to GitHub &amp; push</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">git</span><span> remote </span><span class="token token" style="color: rgb(112, 184, 255);">add</span><span> origin https://github.com/YOUR_USERNAME/cloudtask-manager.git
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">git</span><span> branch -M main
