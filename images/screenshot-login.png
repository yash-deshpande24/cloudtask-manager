────────────────</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Install PostgreSQL if needed: https://www.postgresql.org/download/</span><span>
</span></span><span>psql -U postgres
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Inside psql, run:</span><span>
</span></span><span><span>CREATE DATABASE cloudtask</span><span class="token token" style="color: rgb(211, 215, 222);">;</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(211, 215, 222);">\</span><span>q
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># ── TERMINAL 2: Backend ───────────────────────────</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(251, 173, 96);">cd</span><span> cloudtask-manager/backend
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">npm</span><span> </span><span class="token token" style="color: rgb(112, 184, 255);">install</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">cp</span><span> .env.example .env
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Open .env and set:</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);">#   DB_HOST=localhost</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);">#   DB_PASSWORD=your_postgres_password</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);">#   JWT_SECRET=any_random_secret_string</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">npm</span><span> run dev
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Should say: ✅ Backend running on http://localhost:5000</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># ── TERMINAL 3: Frontend ──────────────────────────</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(251, 173, 96);">cd</span><span> cloudtask-manager/frontend
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">npm</span><span> </span><span class="token token" style="color: rgb(112, 184, 255);">install</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(251, 173, 96);">echo</span><span> </span><span class="token token" style="color: rgb(155, 233, 99);">"REACT_APP_API_URL=http://localhost:5000"</span><span> </span><span class="token token" style="color: rgb(234, 236, 240);">&gt;</span><span> .env
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">npm</span><span> start
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Browser opens automatically at http://localhost:3000</span></span></code></pre></div></div>
<hr class="border-border-200 border-t-0.5 my-3 mx-1.5">
