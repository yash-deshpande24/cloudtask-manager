          transition
          font-base
          duration-300
          ease-[cubic-bezier(0.165,0.85,0.45,1)] h-8 w-8 rounded-md backdrop-blur-md _fill_10ocf_9 _ghost_10ocf_96" type="button" aria-label="Copy to clipboard" data-state="closed"><div class="relative"><div class="transition-all opacity-100 scale-100" style="width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;"><svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="transition-all opacity-100 scale-100" aria-hidden="true" style="flex-shrink: 0;"><path d="M12.5 3A1.5 1.5 0 0 1 14 4.5V6h1.5A1.5 1.5 0 0 1 17 7.5v8a1.5 1.5 0 0 1-1.5 1.5h-8A1.5 1.5 0 0 1 6 15.5V14H4.5A1.5 1.5 0 0 1 3 12.5v-8A1.5 1.5 0 0 1 4.5 3zm1.5 9.5a1.5 1.5 0 0 1-1.5 1.5H7v1.5a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5H14zM4.5 4a.5.5 0 0 0-.5.5v8a.5.5 0 0 0 .5.5h8a.5.5 0 0 0 .5-.5v-8a.5.5 0 0 0-.5-.5z"></path></svg></div><div class="absolute inset-0 flex items-center justify-center"><div class="transition-all opacity-0 scale-50" style="width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;"><svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="transition-all opacity-0 scale-50" aria-hidden="true" style="flex-shrink: 0;"><path d="M15.188 5.11a.5.5 0 0 1 .752.626l-.056.084-7.5 9a.5.5 0 0 1-.738.033l-3.5-3.5-.064-.078a.501.501 0 0 1 .693-.693l.078.064 3.113 3.113 7.15-8.58z"></path></svg></div></div></div></button></div></div><div class="text-text-500 font-small p-3.5 pb-0">bash</div><div class="overflow-x-auto"><pre class="code-block__code !my-0 !rounded-lg !text-sm !leading-relaxed p-3.5" style="color: rgb(234, 236, 240); background: transparent; font-family: var(--font-mono);"><code class="language-bash" style="color: rgb(234, 236, 240); background: transparent; font-family: var(--font-mono); white-space: pre;"><span><span class="token token" style="color: rgb(129, 136, 152);"># Step 1 — Install AWS CLI</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># https://docs.aws.amazon.com/cli/latest/userguide/install-cliv2.html</span><span>
</span></span><span>aws --version
</span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Step 2 — Configure AWS credentials</span><span>
</span></span><span>aws configure
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Enter: AWS Access Key ID</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Enter: AWS Secret Access Key</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Enter: Region (e.g. us-east-1)</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Enter: Output format (json)</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Step 3 — Install Terraform</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># https://developer.hashicorp.com/terraform/downloads</span><span>
</span></span><span>terraform --version
</span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Step 4 — Create EC2 Key Pair in AWS Console</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Go to AWS Console → EC2 → Key Pairs → Create Key Pair</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Download the .pem file → save as cloudtask-key.pem</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">chmod</span><span> </span><span class="token token" style="color: rgb(94, 237, 237);">400</span><span> cloudtask-key.pem
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Step 5 — Deploy infrastructure</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(251, 173, 96);">cd</span><span> cloudtask-manager/terraform
</span></span><span>terraform init
</span><span><span>terraform plan </span><span class="token token" style="color: rgb(211, 215, 222);">\</span><span>
</span></span><span><span>  -var</span><span class="token token" style="color: rgb(234, 236, 240);">=</span><span class="token token" style="color: rgb(155, 233, 99);">"key_pair_name=cloudtask-key"</span><span> </span><span class="token token" style="color: rgb(211, 215, 222);">\</span><span>
</span></span><span><span>  -var</span><span class="token token" style="color: rgb(234, 236, 240);">=</span><span class="token token" style="color: rgb(155, 233, 99);">"db_password=MySecurePass123"</span><span> </span><span class="token token" style="color: rgb(211, 215, 222);">\</span><span>
</span></span><span><span>  -var</span><span class="token token" style="color: rgb(234, 236, 240);">=</span><span class="token token" style="color: rgb(155, 233, 99);">"alert_email=you@gmail.com"</span><span>
</span></span><span><span>terraform apply -auto-approve </span><span class="token token" style="color: rgb(211, 215, 222);">\</span><span>
</span></span><span><span>  -var</span><span class="token token" style="color: rgb(234, 236, 240);">=</span><span class="token token" style="color: rgb(155, 233, 99);">"key_pair_name=cloudtask-key"</span><span> </span><span class="token token" style="color: rgb(211, 215, 222);">\</span><span>
</span></span><span><span>  -var</span><span class="token token" style="color: rgb(234, 236, 240);">=</span><span class="token token" style="color: rgb(155, 233, 99);">"db_password=MySecurePass123"</span><span> </span><span class="token token" style="color: rgb(211, 215, 222);">\</span><span>
</span></span><span><span>  -var</span><span class="token token" style="color: rgb(234, 236, 240);">=</span><span class="token token" style="color: rgb(155, 233, 99);">"alert_email=you@gmail.com"</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Step 6 — Get outputs</span><span>
</span></span><span>terraform output
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Shows: EC2 IP, RDS endpoint, ECR URLs</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Step 7 — Add GitHub Secrets</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Go to: github.com/YOUR_USERNAME/cloudtask-manager</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Settings → Secrets → Actions → New secret</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Add these 5 secrets:</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);">#   AWS_ACCESS_KEY_ID      = your key</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);">#   AWS_SECRET_ACCESS_KEY  = your secret</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);">#   ECR_REGISTRY           = (from terraform output ecr_backend_url, base part)</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);">#   EC2_HOST               = (from terraform output ec2_public_ip)</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);">#   EC2_SSH_KEY            = (paste full contents of cloudtask-key.pem)</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Step 8 — Push to trigger CI/CD</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(112, 184, 255);">git</span><span> push origin main
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># GitHub Actions will automatically:</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># test → build Docker images → push to ECR → deploy to EC2</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># Step 9 — Access live app</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(129, 136, 152);"># http://YOUR_EC2_PUBLIC_IP:3000</span></span></code></pre></div></div>
